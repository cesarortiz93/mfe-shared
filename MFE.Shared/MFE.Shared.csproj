<Project Sdk="Microsoft.NET.Sdk">
	<PropertyGroup>
		<TargetFramework>net8.0</TargetFramework>
		<Nullable>enable</Nullable>
		<ImplicitUsings>enable</ImplicitUsings>

		<!-- Configuración del paquete NuGet -->
		<PackageId>MFE.Shared</PackageId>
		<Version>1.0.0</Version>
		<Authors>César Rolando Ortiz Rangel</Authors>
		<Description>Shared library for MFE Blazor architecture</Description>
		<RepositoryUrl>https://github.com/cesarortiz93/mfe-shared</RepositoryUrl>
		<!-- Aquí termina la configuración -->
		
		<IsPackable>true</IsPackable>
	</PropertyGroup>

	<ItemGroup>
		<PackageReference Include="Microsoft.AspNetCore.Authentication.JwtBearer" Version="8.0.0" />
		<PackageReference Include="Microsoft.IdentityModel.Tokens" Version="7.5.1" />
		<PackageReference Include="System.IdentityModel.Tokens.Jwt" Version="7.5.1" />
	</ItemGroup>
</Project>
